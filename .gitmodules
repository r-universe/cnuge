[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "coil"]
	path = coil
	url = https://github.com/cnuge/coil
	shallow = true
	registered = true
[submodule "debar"]
	path = debar
	url = https://github.com/cnuge/debar
	shallow = true
	registered = true
